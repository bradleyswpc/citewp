# Dependencies
node_modules/
vendor/

# Build output — build/ is committed so WP.org installs get the compiled JS
dist/
*.min.js
*.min.css

# WP / IDE / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.log

# Env / secrets
.env
.env.local
*.pem

# Local WP testing
wp-cli.local.yml

# wp-env Docker state (config is tracked, runtime data is not)
.wp-env.override.json

# npm lockfile noise (we'll commit package-lock.json once we lock versions)
.npm/

# Claude Code local config (hooks + commands tracked, machine state ignored)
.claude/*
!.claude/hooks/
!.claude/commands/
!.claude/settings.json
!.claude/README.md

# Playwright MCP test artifacts (session snapshots, not source)
.playwright-mcp/

# Superpowers framework runtime state
.superpowers/
